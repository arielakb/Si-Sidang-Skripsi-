# App
APP_NAME=Sisidang
APP_ENV=development

# Frontend
FRONTEND_PORT=5173
VITE_API_BASE_URL=http://localhost:5000/api

# Backend
BACKEND_PORT=5000
CORS_ORIGIN=http://localhost:5173

# Database
POSTGRES_USER=sisidang_user
POSTGRES_PASSWORD=sisidang_password
POSTGRES_DB=sisidang_db
DATABASE_URL=postgresql://sisidang_user:sisidang_password@postgres:5432/sisidang_db

# JWT
JWT_ACCESS_SECRET=change_this_access_secret
JWT_REFRESH_SECRET=change_this_refresh_secret
JWT_ACCESS_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# Upload
UPLOAD_DIR=/app/uploads
MAX_FILE_SIZE_MB=100

# Security
BCRYPT_SALT_ROUNDS=12
RATE_LIMIT_WINDOW_MINUTES=15
RATE_LIMIT_MAX_REQUESTS=100

# Seed Admin
SEED_ADMIN_IDENTIFIER=admin
SEED_ADMIN_NAME=Administrator Sisidang
SEED_ADMIN_EMAIL=admin@sisidang.local
SEED_ADMIN_PASSWORD=ChangeMe123!

# Cookie
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
REFRESH_TOKEN_COOKIE_NAME=sisidang_refresh_token

# for production, you might want to set the following values:
#COOKIE_SECURE=true
#COOKIE_SAME_SITE=lax