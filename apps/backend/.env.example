# App
NODE_ENV=development
PORT=5000
APP_NAME=Sisidang

# Database
POSTGRES_USER=sisidang_user
POSTGRES_PASSWORD=sisidang_password
POSTGRES_DB=sisidang_db
DATABASE_URL=postgresql://sisidang_user:sisidang_password@postgres:5432/sisidang_db?schema=public

# Auth
JWT_ACCESS_SECRET=change_this_access_secret
JWT_REFRESH_SECRET=change_this_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
REFRESH_TOKEN_COOKIE_NAME=sisidang_refresh_token

# Cookie / CORS
CORS_ORIGIN=http://localhost:5173
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax

# Seed
SEED_ADMIN_IDENTIFIER=admin
SEED_ADMIN_NAME=Administrator
SEED_ADMIN_EMAIL=admin@sisidang.local
SEED_ADMIN_PASSWORD=ChangeMe123!
BCRYPT_SALT_ROUNDS=10

# Upload
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=10